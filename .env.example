# ============================================
# FireGuard AI - Environment Configuration
# ============================================
# Self-hosted IoT Fire Monitoring System
# Copy this file to .env and configure your database

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Choose ONE option below based on your deployment preference

# --------------------------------------------
# OPTION 1: SQLite (Default - Recommended for Development)
# --------------------------------------------
# ✅ Zero configuration required
# ✅ Perfect for local development and testing
# ✅ Data stored in local file
# ✅ No external database needed

DATABASE_URL="file:./prisma/db/custom.db"

# --------------------------------------------
# OPTION 2: PostgreSQL (Self-Hosted)
# --------------------------------------------
# ✅ Better performance for production
# ✅ Full control over your data
# ✅ Suitable for high-traffic deployments
# 
# Uncomment and configure:
# DATABASE_URL="postgresql://username:password@localhost:5432/fireguard"
#
# Setup PostgreSQL:
# 1. Install PostgreSQL: https://www.postgresql.org/download/
# 2. Create database: createdb fireguard
# 3. Update connection string above
# 4. Change provider in prisma/schema.prisma to "postgresql"
# 5. Run: npm run db:migrate

# --------------------------------------------
# OPTION 3: Supabase (Cloud PostgreSQL)
# --------------------------------------------
# ✅ Free tier available
# ✅ Managed database (no maintenance)
# ✅ Built-in backups and scaling
# ✅ Access from anywhere
#
# Uncomment and configure:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
#
# Setup Supabase:
# 1. Create account: https://supabase.com
# 2. Create new project
# 3. Go to Settings > Database
# 4. Copy connection string (replace [YOUR-PASSWORD])
# 5. Change provider in prisma/schema.prisma to "postgresql"
# 6. Run: npm run db:migrate

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application URL (change for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# ============================================
# OPTIONAL: External Integrations
# ============================================

# OpenRouter AI (for AI Chatbot)
# Get your API key from: https://openrouter.ai/keys
# Free models available: google/gemini-flash-1.5-8b, meta-llama/llama-3.2-3b-instruct:free

# Email Notifications (optional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"

# Telegram Bot (optional - for alerts)
# TELEGRAM_BOT_TOKEN="your-bot-token"
# TELEGRAM_CHAT_ID="your-chat-id"

# Push Notifications (optional)
# VAPID_PUBLIC_KEY="your-public-key"
# VAPID_PRIVATE_KEY="your-private-key"

# ============================================
# NOTES
# ============================================
# - For SQLite: No additional setup needed
# - For PostgreSQL/Supabase: Update prisma/schema.prisma provider
# - Run migrations after changing database: npm run db:migrate
# - Backup your .env file - it contains sensitive data
# - Never commit .env to git (already in .gitignore)

OPENROUTER_API_KEY="sk-or-v1-your-api-key-here"
# Available free models:
# - google/gemini-flash-1.5-8b (Recommended - Fast & High Quality)
# - meta-llama/llama-3.2-3b-instruct:free
# - qwen/qwen-2-7b-instruct:free
# - microsoft/phi-3-mini-128k-instruct:free
# - openai/gpt-oss-20b:free
OPENROUTER_MODEL="openai/gpt-oss-20b:free"